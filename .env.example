# ============================================================
# Pet Podcast — environment variables
# Copy to `.env.local` and fill in values. NEVER commit real keys.
# ============================================================

# --- Supabase (shared project with Stoop Politics) ---
# Project ID: cuxuqsnbxwuhdeajrjcz
NEXT_PUBLIC_SUPABASE_URL=https://cuxuqsnbxwuhdeajrjcz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Schema namespace — keeps Pet Podcast tables isolated from Stoop Politics
NEXT_PUBLIC_SUPABASE_SCHEMA=pet_podcast

# Storage bucket names (created in Supabase Storage)
SUPABASE_BUCKET_AUDIO=pet-podcast-audio
SUPABASE_BUCKET_IMAGES=pet-podcast-images

# --- AI providers ---
# ROTATE the keys you previously pasted into chat. Paste NEW keys only here.
OPENAI_API_KEY=replace_with_new_openai_key
GEMINI_API_KEY=replace_with_new_gemini_key

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.podcast.pet

# --- Podcast Index (cross-platform listen links) ---
# Sign up: https://api.podcastindex.org/signup
# Find feedId: https://podcastindex.org/search?q=<your-show> → click feed → ID in URL
PODCAST_INDEX_KEY=replace_with_podcast_index_key
PODCAST_INDEX_SECRET=replace_with_podcast_index_secret
PODCAST_INDEX_FEED_ID=replace_with_petspective_feed_id
